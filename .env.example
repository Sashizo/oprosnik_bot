APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
TELEGRAM_BOT_TOKEN=
DATABASE_URL=sqlite:///./interview.db
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=30
LLM_GIGACHAT_CREDENTIALS=
# Telegram user_id(s) с доступом к /researcher меню.
# Несколько ID — через запятую: RESEARCHER_TELEGRAM_IDS=123456789,987654321
# При пустом значении researcher-режим недоступен никому.
RESEARCHER_TELEGRAM_IDS=

# ── Security: web admin (HTTP Basic Auth) ────────────────────────────────────
# При пустом ADMIN_PASSWORD web-admin доступен без пароля (dev-mode).
# Задайте надёжный пароль перед любым нелокальным использованием.
ADMIN_USERNAME=researcher
ADMIN_PASSWORD=

# ── Security: input limits & rate limiting ───────────────────────────────────
MAX_MESSAGE_LENGTH=2000
RATE_LIMIT_MESSAGES=10
RATE_LIMIT_CALLBACKS=20
RATE_LIMIT_WINDOW_SECONDS=60

# ── LLM: GigaChat timeout ────────────────────────────────────────────────────
LLM_GIGACHAT_TIMEOUT=30
